---
export interface Props {
  src: string
  alt: string
  href: string
}

const { src, alt, href } = Astro.props
---

<a href={href} class="shrink-0 hidden sm:block hero-thumbnail" style="margin-top: 1em;">
  <div class="hero-thumbnail-wrapper">
    <img
      src={src}
      alt={alt}
      loading="lazy"
      onload="this.parentElement.classList.add('loaded')"
    />
  </div>
</a>

<style>
  .hero-thumbnail-wrapper {
    width: 128px;
    height: 128px;
    border-radius: 12px;
    overflow: hidden;
    background: var(--color-vulcan, #0f111d);
  }

  .hero-thumbnail-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .hero-thumbnail-wrapper.loaded img {
    opacity: 1;
  }
</style>
